@model newMVC.Models.Entities.Student

<div class="container mt-4">
    <h2>Xác nhận xoá</h2>

    <div class="alert alert-danger">
        Bạn có chắc muốn xoá sinh viên này không?
    </div>

    <div class="card">
        <div class="card-body">
            <p><strong>Mã sinh viên:</strong> @Model.StudentCode</p>
            <p><strong>Họ và tên:</strong> @Model.FullName</p>
            <p><strong>Tuổi:</strong> @Model.Age</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Khoa:</strong> @Model.Faculty?.FacultyName</p>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">Xoá</button>
        <a asp-action="Index" class="btn btn-secondary">Huỷ</a>
    </form>
</div>
