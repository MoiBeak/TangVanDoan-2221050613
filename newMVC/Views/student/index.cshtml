@model IEnumerable<newMVC.Models.Entities.Student>

<div class="container mt-4">
    <h2 class="mb-3">Danh sách sinh viên</h2>

    <a asp-action="Create" class="btn btn-primary mb-3">Thêm sinh viên</a>
    <a asp-action="Upload" class="btn btn-success">Import Excel</a>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Student Code</th>
                <th>Full Name</th>
                <th>Age</th>
                <th>Email</th>
                <th>Faculty</th> <!-- Thêm cột Khoa -->
                <th width="180">Action</th>
            </tr>
        </thead>

        <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.StudentCode</td>
                    <td>@item.FullName</td>
                    <td>@item.Age</td>
                    <td>@item.Email</td>
                    <td>@item.Faculty?.FacultyName</td> <!-- Hiển thị tên khoa -->
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                        
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-danger">
                    Chưa có dữ liệu sinh viên
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
